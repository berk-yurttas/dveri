# ── General API ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:8000

# ── OpenProject Feedback Widget ─────────────────────────────
# Backend URL of the standalone widget backend (auto-resolves to localhost:8787 if omitted)
NEXT_PUBLIC_OPENPROJECT_WIDGET_BACKEND_BASE_URL=http://localhost:8787

# The values below are optional overrides.
# If the widget backend already has these in its own .env, you can leave them blank here.
NEXT_PUBLIC_OPENPROJECT_URL=http://localhost:8080
NEXT_PUBLIC_OPENPROJECT_API_TOKEN=
NEXT_PUBLIC_OPENPROJECT_PROJECT_ID=3
NEXT_PUBLIC_OPENPROJECT_COLUMN_QUERY_ID=30
NEXT_PUBLIC_OPENPROJECT_PLATFORM_CUSTOM_FIELD_ID=2
NEXT_PUBLIC_OPENPROJECT_TALEP_SAHIBI_CUSTOM_FIELD_ID=3
NEXT_PUBLIC_OPENPROJECT_BIRIM_CUSTOM_FIELD_ID=4
NEXT_PUBLIC_OPENPROJECT_TYPE_ID=1
NEXT_PUBLIC_OPENPROJECT_VERIFY_SSL=false

