# BACKEND `.env`
# Copy this file to `backend/.env`
# Used by: `backend/index.js`, auth, DB and scripts.

# ---------------------------------
# Required app runtime configuration
# ---------------------------------
PORT=5010
JWT_SECRET=change-me-to-a-long-random-string

# PostgreSQL connection
# Local DB example:
DATABASE_URL=postgresql://card:card@127.0.0.1:5433/cardgame
# Docker-internal example (if backend runs inside compose):
# DATABASE_URL=postgresql://card:card@postgres:5432/cardgame

# true for cloud DB providers requiring SSL, false for local Docker/Postgres
PGSSL=false

# ---------------------------------------
# Optional: Mongo -> Postgres migration
# ---------------------------------------
# MONGODB_URI=mongodb://127.0.0.1:27017/cardgame
# MONGODB_DB_NAME=cardgame

# ---------------------------------------
# Optional: card image import script only
# ---------------------------------------
# CARD_IMAGES_DIR=C:\Users\you\Documents\GitHub\Card\card_images
# CARD_IMAGE_BASE_URL=http://localhost:5010
# CARD_DEFAULT_ATTACK=12
# CARD_DEFAULT_DEFENSE=8
# CARD_DEFAULT_HEALTH=45

