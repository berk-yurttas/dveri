# ROOT `.env` (Docker Compose)
# Copy this file to `.env` in repository root.
# Used by: `docker-compose.yml`

# ---------------------------
# PostgreSQL container config
# ---------------------------
POSTGRES_DB=cardgame
POSTGRES_USER=card
POSTGRES_PASSWORD=card

# Host port mappings (host:container)
POSTGRES_HOST_PORT=5433
BACKEND_HOST_PORT=5010
FRONTEND_HOST_PORT=3001

# ---------------------------
# Backend runtime config
# ---------------------------
JWT_SECRET=change-me-to-a-long-random-string
PGSSL=false

# ---------------------------
# Frontend runtime config
# ---------------------------
# Frontend will call backend through this URL.
# For intranet, set your backend host/IP:
# REACT_APP_API_URL=http://10.0.0.15:5010
REACT_APP_API_URL=http://localhost:5010

# ---------------------------
# Optional one-time migration
# ---------------------------
# MONGODB_URI=mongodb://127.0.0.1:27017/cardgame
