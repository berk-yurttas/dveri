# FRONTEND `.env`
# Copy this file to `frontend/.env` (or `.env.local`).
# Only variables prefixed with REACT_APP_ are exposed to browser code.

# Backend API base URL (REST + Socket.IO)
# Local example:
REACT_APP_API_URL=http://localhost:5010

# Intranet example:
# REACT_APP_API_URL=http://10.0.0.15:5010

# Public deployment example:
# REACT_APP_API_URL=https://your-api.example.com
