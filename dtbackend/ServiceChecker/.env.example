# Copy to .env and adjust. DATABASE_URL must point at your PostgreSQL instance.
# With Docker Compose, the app uses DATABASE_URL from docker-compose.yml (db:5432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/servicechecker
SECRET_KEY=change-me
FLASK_DEBUG=0
PORT=5000
CHECK_INTERVAL_MINUTES=5
REQUEST_TIMEOUT_SECONDS=10
